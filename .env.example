# ─────────────────────────────────────────────────────────────
# nycgrid — environment variable reference
# Copy this file to .env.local and fill in your values.
# See docs/setup/ for a setup guide for each service.
# ─────────────────────────────────────────────────────────────

# ── NYC Open Data (events) ───────────────────────────────────
# Optional. Enables the "What's Happening Now" event labels.
# Guide: docs/setup/nyc-open-data.md
NYC_OPEN_DATA_APP_TOKEN=

# ── 511NY (transit alerts) ───────────────────────────────────
# Optional. Enables MTA service alert context in camera panels.
# Guide: docs/setup/transit.md
NYC_511_API_KEY=

# ── MTA Bus Time (real-time bus arrivals) ────────────────────
# Optional. Shows live bus arrivals for street-level cameras.
# Guide: docs/setup/bustime.md
MTA_BUS_TIME_KEY=

# ── App URL ──────────────────────────────────────────────────
# Used for robots.txt, sitemap, and OG metadata.
NEXT_PUBLIC_APP_URL=https://nycgrid.vercel.app

# ── Brand domain (OG images, photobooth watermark) ───────────
# Optional. Defaults to "nycgrid.vercel.app" if unset.
NEXT_PUBLIC_BRAND_DOMAIN=
