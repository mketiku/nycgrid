{
  "name": "nycgrid",
  "version": "0.1.1",
  "private": true,
  "packageManager": "bun@1.3.12",
  "scripts": {
    "dev": "next dev -p 3200",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:unit": "vitest run --project unit",
    "test:component": "vitest run --project component",
    "test:integration": "vitest run --project integration",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "validate:commit": "node scripts/run-hook-checks.mjs pre-commit",
    "validate:push": "node scripts/run-hook-checks.mjs pre-push",
    "capture:all": "node scripts/capture-screenshots.mjs && node scripts/capture-video.mjs",
    "capture:screenshots": "node scripts/capture-screenshots.mjs",
    "capture:screenshots:local": "BASE_URL=http://localhost:3100 node scripts/capture-screenshots.mjs",
    "capture:video": "node scripts/capture-video.mjs",
    "capture:video:local": "BASE_URL=http://localhost:3100 node scripts/capture-video.mjs",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.99.2",
    "@turf/area": "^7.3.5",
    "@turf/boolean-point-in-polygon": "^7.3.5",
    "@vercel/analytics": "^2.0.1",
    "clsx": "^2.1.1",
    "gifenc": "^1.0.3",
    "lucide-react": "^1.8.0",
    "maplibre-gl": "^5.23.0",
    "motion": "^12.38.0",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.2.1",
    "eslint-config-next": "^16.2.4",
    "eslint-config-prettier": "^10.1.8",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "msw": "^2.13.4",
    "prettier": "^3.8.3",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.5"
  },
  "trustedDependencies": [
    "msw",
    "protobufjs",
    "sharp",
    "unrs-resolver"
  ],
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "vitest related --run --project=unit"
    ],
    "*.{js,jsx}": [
      "eslint --fix"
    ],
    "*.{ts,tsx,js,jsx,json,css,md}": [
      "prettier --write"
    ]
  }
}
