# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — keep example template but ignore everything else
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Claude Code
.claude/worktrees/

# Playwright CLI
.playwright-cli/

# Marketing assets — regenerate with node scripts/capture-screenshots.mjs / capture-video.mjs
/scripts/screenshots/

# Launch planning — local only, not tracked in git
/launch/

# Daily planning — local scratch file
PLAN_OF_DAY.md
.env*.local
